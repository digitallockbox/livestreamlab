# Used by frontend auth/web3 pages to reach backend directly.
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:4000

# Used by /api/dashboard proxy routes.
# In development, this defaults to http://localhost:4000 when unset.
# Set explicitly for staging/production APIs.
DASHBOARD_API_BASE_URL=https://api.livestreamlab.live
DASHBOARD_API_TOKEN=
